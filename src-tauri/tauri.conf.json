{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Desktop",
  "version": "0.1.7",
  "identifier": "com.codexdesktop.linux",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": false
  },
  "app": {
    "enableGTKAppId": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "create": false,
        "dragDropEnabled": false,
        "label": "main",
        "title": "Codex Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": [
        "window-controls",
        "app-events",
        "app-windows",
        "configuration",
        "configured-connection",
        "local-stdio",
        "remote-websocket"
      ],
      "csp": "default-src 'self'; base-uri 'none'; connect-src ipc: http://ipc.localhost; font-src 'self'; form-action 'none'; frame-ancestors 'none'; frame-src 'none'; img-src 'self' blob:; manifest-src 'self'; media-src 'none'; object-src 'none'; script-src 'self'; style-src 'self'; worker-src 'self' blob:",
      "devCsp": "default-src 'self'; base-uri 'none'; connect-src ipc: http://ipc.localhost ws://localhost:1421; font-src 'self'; form-action 'none'; frame-ancestors 'none'; frame-src 'none'; img-src 'self' blob:; manifest-src 'self'; media-src 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:",
      "freezePrototype": true,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Resource-Policy": "same-origin",
        "Permissions-Policy": "camera=(), display-capture=(), geolocation=(), microphone=()",
        "X-Content-Type-Options": "nosniff"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Codex Desktop client for Linux",
    "longDescription": "A native Linux desktop client for local and remote Codex app-server connections.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "desktopTemplate": "linux/codex-desktop.desktop"
      },
      "rpm": {
        "desktopTemplate": "linux/codex-desktop.desktop"
      }
    }
  }
}
